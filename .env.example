# ─── Database ────────────────────────────────────────────────────────────────
DB_USERNAME=joy_user
DB_PASSWORD=change_me_strong_password
DB_DATABASE=joy_morocco

# ─── Backend ─────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_64_char_random_secret

# Comma-separated list of allowed frontend origins for CORS
FRONTEND_URL=https://booking.yourdomain.com,https://admin.yourdomain.com

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_SUBJECT=mailto:you@yourdomain.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── Frontend build args (baked into JS at build time) ───────────────────────
# Public API URL — shown in browser requests, used as fallback for dev
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# Server-side API URL — used by Next.js rewrites proxy (internal Docker network)
# In docker-compose this is set automatically; only override if needed
# API_URL=http://backend:3100

# Hostnames used for cross-portal links (no protocol, no trailing slash)
NEXT_PUBLIC_BOOKING_HOST=booking.yourdomain.com
NEXT_PUBLIC_ADMIN_HOST=admin.yourdomain.com
