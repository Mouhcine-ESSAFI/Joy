# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3100

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=yourpassword
DB_DATABASE=joy_morocco

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate strong secrets: openssl rand -base64 64
JWT_SECRET=change-me-min-32-chars-long-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-different-refresh-secret-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cookie ───────────────────────────────────────────────────────────────────
# Set COOKIE_SECURE=true in production (requires HTTPS)
COOKIE_SECURE=false
# Set COOKIE_DOMAIN=.joymorocco.com in production for subdomain sharing
COOKIE_DOMAIN=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# In production: comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:9002

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate keys: npx web-push generate-vapid-keys
# IMPORTANT: VAPID_PUBLIC_KEY must exactly match frontend NEXT_PUBLIC_VAPID_PUBLIC_KEY
VAPID_SUBJECT=mailto:admin@joymorocco.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
