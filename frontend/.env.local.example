# ─── Backend API ──────────────────────────────────────────────────────────────
# Full URL to the backend (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:3100

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Must match backend VAPID_PUBLIC_KEY exactly — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
